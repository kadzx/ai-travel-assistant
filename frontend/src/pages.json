{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/login/login",
			"style": {
				"navigationBarTitleText": "登录 / 注册"
			}
		},
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "我的行程"
			}
		},
		{
			"path": "pages/itinerary/create",
			"style": {
				"navigationBarTitleText": "创建新行程"
			}
		},
		{
			"path": "pages/chat/chat",
			"style": {
				"navigationBarTitleText": "AI 助手"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "AI Travel",
		"navigationBarBackgroundColor": "#FFFFFF",
		"backgroundColor": "#F8F8F8"
	},
	"tabBar": {
		"color": "#909399",
		"selectedColor": "#3c9cff",
		"backgroundColor": "#FFFFFF",
		"borderStyle": "black",
		"list": [
			{
				"pagePath": "pages/index/index",
				"text": "行程",
				"iconPath": "static/tabbar/home.png",
				"selectedIconPath": "static/tabbar/home-active.png"
			},
			{
				"pagePath": "pages/chat/chat",
				"text": "AI 对话",
				"iconPath": "static/tabbar/chat.png",
				"selectedIconPath": "static/tabbar/chat-active.png"
			}
		]
	}
}