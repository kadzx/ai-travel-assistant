# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=123456
DB_NAME=ai_travel_db
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Coze (ByteDance AI) Configuration
# Get these from https://www.coze.cn/
COZE_API_TOKEN=your_coze_personal_access_token
COZE_BOT_ID=your_coze_bot_id
COZE_API_BASE_URL=https://api.coze.cn/open_api/v2/chat

# Coze 站点工作流（聊天 + 行程生成，见 docs/Coze工作流接入计划.md）
COZE_SITE_STREAM_URL=https://your-workflow.coze.site/stream_run
COZE_SITE_TOKEN=your_coze_site_bearer_token
COZE_PROJECT_ID=your_project_id
# 调试：设为 1 时在控制台打印每条 Coze SSE 事件的 type 和字段名
# COZE_DEBUG_STREAM=1

# 小红书图片迁移脚本用：下载后的图片访问根地址（见 xhs-crawler/download_xhs_images.py）
# UPLOAD_BASE_URL=http://localhost:3000
