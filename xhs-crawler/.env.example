# 小红书 Cookie（浏览器登录 xiaohongshu.com 后从 F12 → Network 请求头里复制）
XHS_A1=你的a1值
XHS_WEB_SESSION=你的web_session值
XHS_WEB_ID=你的webId值

# 毕设数据库（可与 backend 一致，或单独配置）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=travel_db

# 爬虫专用用户 ID（阶段 3 导入时 posts.user_id 写入该用户）
CRAWLER_USER_ID=2

# 搜索关键词（阶段 1）
KEYWORD=旅游规划

# 可选：请求间隔（秒），建议 1~2 避免风控
CRAWL_DELAY=1.5

# 可选：最多爬取笔记条数，0 表示不限制
CRAWL_MAX_NOTES=200
