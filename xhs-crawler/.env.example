# 毕设数据库（阶段 3 导入时用）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=travel_db

# 爬虫专用用户 ID（导入 posts 时写入该 user_id）
CRAWLER_USER_ID=2

# 关键词（若爬取方案支持按关键词过滤）
KEYWORD=旅游规划

# 基础间隔（秒），实际会加随机 3~8s；建议 15 以上降低限流
CRAWL_DELAY=15
CRAWL_MAX_NOTES=200
# 每滚动几次休息一次、休息多少秒（0 表示不休息）
CRAWL_REST_EVERY=5
CRAWL_REST_SECONDS=60
